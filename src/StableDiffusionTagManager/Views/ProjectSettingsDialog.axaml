<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="StableDiffusionTagManager.Views.ProjectSettingsDialog"
        MinHeight="380"
        Height="800"
        Width="460"
        xmlns:controls="using:StableDiffusionTagManager.Controls"
        xmlns:conv="using:StableDiffusionTagManager.Converters"
        xmlns:api="using:SdWebUiApi"
        CanResize="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="4"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterOwner"
        Title="Project Settings"
        Icon="/Assets/logo.ico"
        Name="ThisControl">
  <Window.Styles>
    <Style Selector="RadioButton">
      <Setter Property="Margin" Value="5,0,0,0"></Setter>
    </Style>
  </Window.Styles>
  <Window.Resources>
    <conv:InterrogateMethodToBooleanConverter x:Key="interrogateConverter"/>
  </Window.Resources>
  <controls:HeaderControl DataContext="{Binding ElementName=ThisControl}" Title="Project Settings" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="5" CloseCommand="{Binding CancelCommand}">
    <DockPanel>
      <!-- Footer pinned to the bottom -->
      <StackPanel DockPanel.Dock="Bottom" Classes="footer">
        <Button Command="{Binding SaveCommand}">Save</Button>
        <Button Command="{Binding CancelCommand}">Cancel</Button>
      </StackPanel>

      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,*" ColumnDefinitions="*,Auto">
        <Label>Default Prompt Prefix</Label>
        <TextBox Width="200" Grid.Column="1" Text="{Binding DefaultPromptPrefix}" />

        <Label Grid.Row="1">Default Negative Prompt</Label>
        <TextBox Width="200" Grid.Row="1" Grid.Column="1" Text="{Binding DefaultNegativePrompt}" />

        <Label Grid.Row="2">Activation Keyword</Label>
        <TextBox Width="200" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ActivationKeyword}" />

        <Label Grid.Row="3">Default Denoise Strength</Label>
        <NumericUpDown HorizontalAlignment="Right" Grid.Row="3" Grid.Column="1" Value="{Binding DefaultDenoiseStrength}" Width="100" Minimum="0" Maximum="1" Increment="0.1"/>

        <Grid Grid.Row="4" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,*,Auto">
          <Label>Image Width</Label>
          <NumericUpDown Grid.Column="1" Value="{Binding TargetImageWidth}" Width="100" Minimum="0"/>
          <Label Grid.Column="2">Image Height</Label>
          <NumericUpDown Grid.Column="3" Value="{Binding TargetImageHeight}" Width="100" Minimum="0"/>
        </Grid>

        <Label Grid.Row="5">Interrogation Endpoint URL</Label>
        <TextBox Width="200" Grid.Row="5" Grid.Column="1" Text="{Binding DefaultInterrogationEndpointUrl}" Watermark="http://localhost:11434" />

        <Label Grid.Row="6" Grid.ColumnSpan="2">Default NL Interrogation Prompt</Label>
        <TextBox Grid.Row="7" Grid.ColumnSpan="2"
                 Text="{Binding DefaultNaturalLanguageInterrogationPrompt}"
                 Watermark="Describe this image in detail."
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Height="60" VerticalContentAlignment="Top" />

        <Label Grid.Row="8" Grid.ColumnSpan="2">Default Tag Interrogation Prompt</Label>
        <TextBox Grid.Row="9" Grid.ColumnSpan="2"
                 Text="{Binding DefaultTagInterrogationPrompt}"
                 Watermark="List tags for this image, comma separated."
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Height="60" VerticalContentAlignment="Top" />

        <!-- Concepts editor -->
        <Grid Grid.Row="10" Grid.ColumnSpan="2" RowDefinitions="Auto,*" Margin="0,6,0,0" MinHeight="80">
          <DockPanel Grid.Row="0">
            <Label FontWeight="SemiBold">Concepts</Label>
            <Button DockPanel.Dock="Right" Command="{Binding AddConceptCommand}"
                    HorizontalAlignment="Right" Padding="6,2" ToolTip.Tip="Add concept">+</Button>
          </DockPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Concepts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,8,*,Auto" Margin="0,2">
                    <TextBox Grid.Column="0" Text="{Binding Key, Mode=TwoWay}"
                             Watermark="KEY" />
                    <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay}"
                             Watermark="value" />
                    <Button Grid.Column="3" Margin="4,0,0,0" Padding="6,2"
                            Command="{Binding ElementName=ThisControl, Path=RemoveConceptCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Remove">✕</Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
        <!-- Response strip pairs editor -->
        <Grid Grid.Row="11" Grid.ColumnSpan="2" RowDefinitions="Auto,*" Margin="0,6,0,0" MinHeight="80">
          <DockPanel Grid.Row="0">
            <Label FontWeight="SemiBold">Response Strip Pairs</Label>
            <Button DockPanel.Dock="Right" Command="{Binding ElementName=ThisControl, Path=AddStripPairCommand}"
                    HorizontalAlignment="Right" Padding="6,2" ToolTip.Tip="Add strip pair">+</Button>
          </DockPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ElementName=ThisControl, Path=StripPairs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,8,*,Auto" Margin="0,2">
                    <TextBox Grid.Column="0" Text="{Binding Open, Mode=TwoWay}"
                             Watermark="open tag" />
                    <TextBox Grid.Column="2" Text="{Binding Close, Mode=TwoWay}"
                             Watermark="close tag" />
                    <Button Grid.Column="3" Margin="4,0,0,0" Padding="6,2"
                            Command="{Binding ElementName=ThisControl, Path=RemoveStripPairCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Remove">✕</Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Grid>
    </DockPanel>
  </controls:HeaderControl>
</Window>
