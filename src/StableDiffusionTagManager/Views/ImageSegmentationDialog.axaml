<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:StableDiffusionTagManager.Controls"
        xmlns:viewmodels="using:StableDiffusionTagManager.ViewModels"
        xmlns:behaviors="clr-namespace:StableDiffusionTagManager.Behaviors;assembly=StableDiffusionTagManager"
        xmlns:ia="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="440"
        Height="440"
        MinHeight="360"
        Width="600"
        x:Class="StableDiffusionTagManager.Views.ImageSegmentationDialog"
        Title="Image Segmentation"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="4"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/logo.ico"
        CanResize="True"
        KeyDown="WindowKeyDown">
  <ia:Interaction.Behaviors>
    <behaviors:CloseWindowOnEventBehavior EventName="RequestClose" />
  </ia:Interaction.Behaviors>
  <controls:HeaderControl Title="Image Segmentation">
    <Grid RowDefinitions="*,Auto">
      <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabItem Header="Kumiko">
          <StackPanel Margin="8" Spacing="8">
            <TextBlock TextWrapping="Wrap">
              Use Kumiko to automatically detect comic panel boundaries from the image.
              No additional configuration required.
            </TextBlock>
          </StackPanel>
        </TabItem>
        <TabItem Header="LLM Segmentation">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Classes="inputform">
              <Panel>
                <Label Content="Endpoint Type"/>
                <ComboBox ItemsSource="{x:Static viewmodels:ImageSegmentationViewModel.EndpointTypes}"
                          SelectedItem="{Binding SelectedEndpointType, Mode=TwoWay}" />
              </Panel>
              <Panel>
                <Label Content="Endpoint URL"/>
                <TextBox Text="{Binding EndpointUrl}" Width="300"/>
              </Panel>
              <Panel>
                <Label Content="Model"/>
                <TextBox Text="{Binding Model}" Watermark="llava:13b" Width="200"/>
              </Panel>
              <Panel>
                <Label Content="API Key (OpenAI only)"/>
                <TextBox Text="{Binding ApiKey}" Width="300" PasswordChar="*"/>
              </Panel>
              <Panel>
                <Label Content="Max Image Dimension"/>
                <NumericUpDown Value="{Binding MaxImageDimension, Mode=TwoWay}" Minimum="0" Maximum="8192" Increment="64" Width="120" FormatString="0"/>
              </Panel>
            </StackPanel>
            <Grid Grid.Row="1" RowDefinitions="Auto,*">
              <Label Grid.Row="0" Margin="2,6,2,2">Prompt</Label>
              <TextBox Grid.Row="1"
                       Text="{Binding Prompt}" AcceptsReturn="True" TextWrapping="Wrap"
                       VerticalContentAlignment="Top" MinHeight="80" Margin="2,0,2,4"/>
            </Grid>
          </Grid>
        </TabItem>
      </TabControl>
      <StackPanel Grid.Row="1" Classes="footer">
        <Button Command="{Binding OkCommand}">Segment</Button>
        <Button Command="{Binding CancelCommand}">Cancel</Button>
      </StackPanel>
    </Grid>
  </controls:HeaderControl>
</Window>
