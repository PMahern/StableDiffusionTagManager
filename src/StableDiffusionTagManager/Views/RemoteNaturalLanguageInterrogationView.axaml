<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:StableDiffusionTagManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="StableDiffusionTagManager.Views.RemoteNaturalLanguageInterrogationView">

  <Grid RowDefinitions="Auto,Auto,*">
    <StackPanel Grid.Row="0" Classes="inputform">
      <Panel>
        <Label Content="Endpoint Type"/>
        <ComboBox ItemsSource="{x:Static viewmodels:RemoteNaturalLanguageInterrogationViewModel.EndpointTypes}"
                  SelectedItem="{Binding SelectedEndpointType, Mode=TwoWay}" />
      </Panel>
      <Panel>
        <Label Content="Endpoint URL"/>
        <TextBox Text="{Binding EndpointUrl}" Watermark="http://localhost:11434" Width="300"/>
      </Panel>
      <Panel>
        <Label Content="Model"/>
        <TextBox Text="{Binding Model}" Watermark="llava:13b (Ollama only)" Width="200"/>
      </Panel>
    </StackPanel>
    <Label Grid.Row="1" Margin="2,6,2,2">Prompt</Label>
    <TextBox Grid.Row="2"
             Text="{Binding Prompt}" AcceptsReturn="True" TextWrapping="Wrap"
             VerticalContentAlignment="Top" MinHeight="80" Margin="2,0,2,4"/>
  </Grid>
</UserControl>
